# VisionGate secrets — COPY THIS FILE to ".env" and fill in real values.
# The real ".env" is git-ignored and will NOT be committed or shared.
# Leave any line out to keep the (insecure) demo default.

# Shared key the Raspberry Pi must send. Must match visiongate/config.py API_KEY.
VISIONGATE_API_KEY=change-me-to-a-long-random-string

# Dashboard admin login.
VISIONGATE_ADMIN_USER=admin
VISIONGATE_ADMIN_PASSWORD=change-me

# Signs the login session cookie — make this long and random.
VISIONGATE_SECRET_KEY=change-me-to-a-long-random-string

# Telegram alerts (only if ALERT_BACKEND = "telegram" in config.py).
VISIONGATE_TELEGRAM_TOKEN=
VISIONGATE_TELEGRAM_CHAT_ID=
